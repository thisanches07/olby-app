{
  "rewrites": [
    { "source": "/privacy",        "destination": "/legal/privacy.html" },
    { "source": "/terms",          "destination": "/legal/terms.html" },
    { "source": "/auth-action",    "destination": "/legal/auth-action.html" },
    { "source": "/reset-password", "destination": "/legal/reset-password.html" },
    { "source": "/verify-email",   "destination": "/legal/verify-email.html" },
    { "source": "/delete-account", "destination": "/legal/delete-account.html" },
    { "source": "/styles.css",     "destination": "/legal/styles.css" }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [{ "key": "Content-Type", "value": "application/json" }]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [{ "key": "Content-Type", "value": "application/json" }]
    }
  ]
}
