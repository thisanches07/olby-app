{
  "name": "obra-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client --host lan",
    "start:dev-client:tunnel": "expo start --dev-client --tunnel",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:dev:build": "npx eas build --platform ios --profile development",
    "ios:build": "npx eas build --platform ios --profile production",
    "ios:submit": "npx eas submit --platform ios --latest",
    "ios:release": "npx eas build --platform ios --profile production --auto-submit",
    "android:build": "npx eas build --platform android --profile production",
    "android:submit": "npx eas submit --platform android --latest",
    "android:release": "npx eas build --platform android --profile production --auto-submit",
    "web": "expo start --web",
    "lint": "expo lint",
    "test:billing": "tsx tests/billing-api.mappers.test.mts",
    "test:permissions": "tsx tests/project-role.permissions.test.mts"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "^2.0.2",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "^55.0.11",
    "expo-clipboard": "^8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-firebase-recaptcha": "^1.4.4",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-iap": "^3.4.9",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-media-library": "~18.2.1",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.9.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-document-scanner-plugin": "^2.0.4",
    "react-native-draggable-flatlist": "^4.0.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
